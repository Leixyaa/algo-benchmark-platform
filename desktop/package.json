{
  "name": "algo-benchmark-platform-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Minimal Electron shell for algo-benchmark-platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:web": "npm --prefix ../web run build:desktop",
    "pack": "npm run build:web && electron-builder --dir",
    "dist": "npm run build:web && electron-builder"
  },
  "build": {
    "appId": "com.abp.desktop",
    "productName": "Algo Benchmark Platform Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "splash.html",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "devDependencies": {
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12"
  }
}
